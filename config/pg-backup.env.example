# Copy to /etc/ener-scan/pg-backup.env (chmod 600) on the Hetzner server.
# Used by scripts/ops/pg-backup.sh

# Space-separated databases to dump (production first).
PG_DATABASES="ener_scan_pro ener_scan"

# Local staging directory (must exist; script creates daily subdirs).
BACKUP_DIR=/var/backups/ener-scan-pg

# Keep this many daily dumps per database (local + remote prune).
RETENTION_DAYS=7

# none | aws | rclone
UPLOAD_MODE=none

# --- Cloudflare R2 (S3-compatible) via AWS CLI ---
# Install: apt install -y awscli  (or pip install awscli)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# AWS_DEFAULT_REGION=auto
# S3_BUCKET=ener-scan-backups
# S3_PREFIX=postgres

# --- Backblaze B2 (S3-compatible) via AWS CLI ---
# AWS_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
# AWS_DEFAULT_REGION=<region>

# --- rclone (R2 or B2) ---
# Install: apt install -y rclone && rclone config
# RCLONE_REMOTE=r2:ener-scan-backups/postgres
