# LINE
CHANNEL_SECRET=
CHANNEL_ACCESS_TOKEN=
# Dozzle monitor OTP (LINE push to this user)
MONITOR_ADMIN_LINE_USER_ID=

# AI
OPENAI_API_KEY=
GEMINI_API_KEY=

# Front conversation LLM provider: google (default) | openrouter | featherless
LLM_FRONT_PROVIDER=google
# Required when LLM_FRONT_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FRONT_MODEL=google/gemini-2.5-flash-lite
# Required when LLM_FRONT_PROVIDER=featherless (OpenAI-compatible)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_FRONT_MODEL=deepseek-ai/DeepSeek-V3-0324

# Supabase (temporary - will replace in Phase 2)

# Redis (local Docker)
REDIS_URL=redis://redis:6379

# Storage buckets
SCAN_OBJECT_IMAGE_BUCKET=scan-object-images
SCAN_V2_UPLOAD_BUCKET=scan-uploads
PAYMENT_SLIP_BUCKET=payment-slips

# App
PORT=3000
NODE_ENV=production

# Ener-AI event bridge (Core V2 Batch 4)
ENER_AI_EVENT_ENABLED=false
ENER_AI_EVENT_URL=http://ener-ai:8000/ai/event
ENER_AI_EVENT_TOKEN=
ENER_AI_EVENT_TIMEOUT_MS=2500

# Amulet scoring stability (same object / different angle)
# A+B: angle-robust feature_blend_v3 scoring requires the stable feature extract to be on.
# Enabled: fresh single_supported scans run a stable-feature vision pass; falls back to
# the legacy hash seed automatically if the extract fails/times out.
STABLE_FEATURE_SEED_ENABLED=true
# C: semantic embedding nearest-neighbor baseline reuse (requires sql/034 migration + pgvector).
OBJECT_EMBEDDING_PERSIST_ENABLED=false
CROSS_ACCOUNT_BASELINE_EMBEDDING_REUSE_ENABLED=false
CROSS_ACCOUNT_BASELINE_EMBEDDING_MIN_SIMILARITY=0.92
OBJECT_EMBEDDING_MODEL=text-embedding-3-small
OBJECT_EMBEDDING_DESCRIPTOR_MODEL=gpt-4.1-mini
OBJECT_EMBEDDING_TIMEOUT_MS=14000
# D: multi-angle enrollment (requires sql/035 migration).
OBJECT_ENROLLMENT_ENABLED=false
# F: same-object verifier agent. Embedding becomes a coarse recall filter and a vision LLM confirms
# "same physical object across angle/rotation/flip?" before any reuse. Requires C enabled.
OBJECT_SAME_IDENTITY_VERIFIER_ENABLED=false
CROSS_ACCOUNT_BASELINE_EMBEDDING_RECALL_MIN_SIMILARITY=0.45
OBJECT_SAME_IDENTITY_VERIFIER_MIN_CONFIDENCE=0.8
OBJECT_SAME_IDENTITY_VERIFIER_MAX_CANDIDATES=5
# Recency safety-net: also show the verifier the N newest baselines (embedding is unreliable under crop/zoom). 0 = off.
OBJECT_SAME_IDENTITY_VERIFIER_RECENT_CANDIDATES=4
OBJECT_SAME_IDENTITY_VERIFIER_MODEL=gpt-4.1-mini

# --- Voice note "เสียงอาจารย์" ท้าย flex report (ElevenLabs → m4a → R2 → LINE audio) ---
VOICE_NOTE_ENABLED=false
# paid_and_first_free = จ่ายเงิน:ทุกสแกน / ฟรี:สแกนแรกครั้งเดียวในชีวิต | all = เทสบน staging
VOICE_NOTE_AUDIENCE=paid_and_first_free
VOICE_NOTE_TIMEOUT_MS=15000
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=KaT6JiTgr6OcQNnpAc35
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_SPEED=0.85

# --- Phase 1 image forensics (ธง screen-photo / AI-generated / edited) ---
IMAGE_FORENSIC_ENABLED=false
IMAGE_FORENSIC_MODEL=gpt-4.1-mini
IMAGE_FORENSIC_TIMEOUT_MS=25000
IMAGE_FORENSIC_SCREEN_MIN_CONF=0.85
IMAGE_FORENSIC_AI_MIN_CONF=0.9
# ท้าถ่ายสดเมื่อรูปติดธงสงสัย (ต้องมี vision sidecar)
AUTH_CHALLENGE_ENABLED=false
AUTH_CHALLENGE_MIN_INLIERS=18
AUTH_CHALLENGE_TTL_SEC=900
AUTH_CHALLENGE_INCLUDE_PAID=false
AMULET_REFS_TOKEN=
# ข้อความปัดรูปแต่งสดด้วย LLM (รู้จำนวนครั้งที่โดนปัด) — fail-open ใช้ข้อความเดิม
SMART_REJECTION_ENABLED=true
SMART_REJECTION_MODEL=gpt-4.1-mini

# --- Auto post Facebook "อวดพระขึ้นเพจ" (กบ 22 ก.ค. 2026) ---
# token เพจจากระบบ Connect ใน ener-ai (/admin/facebook) — ไม่มีค่า = ฟีเจอร์ปิดทั้งชุด
FB_PAGE_ID=
FB_PAGE_TOKEN=
FB_API_VERSION=v21.0
FB_AUTOPOST_ENABLED=true
FB_CONSENT_ASK_ENABLED=true
FB_CONSENT_MIN_SCORE=8
FB_AUTOPOST_HOURS=11,19
# โพสต์แบบซ่อน (ทดสอบ) — true = ไม่ขึ้นหน้าเพจ
FB_AUTOPOST_UNPUBLISHED=false
FB_LIBRARY_LINE_USER_ID=Ufe02fffb43200f2a32eabb919130ed9b
FB_CAPTION_OA_LINK=https://lin.ee/6YZeFZ1
# โหมดทดสอบ: สแกนชิ้นจากบัญชี FB_LIBRARY_LINE_USER_ID → โพสต์ขึ้นเพจทันที (ใช้บน staging)
FB_AUTOPOST_ON_SCAN=false

# --- ระบบชวนเพื่อน (กบ 23 ก.ค. 2026) ---
REFERRAL_ENABLED=true
REFERRAL_MONTHLY_CAP=5
# การ์ดภาพในแชทแทน Flex สรุป (แบบ B — รูปซูมได้ + Flex ใบเล็ก) — เปิดทดสอบบน staging ก่อน
SCAN_CHAT_PHOTO_CARD_ENABLED=false
